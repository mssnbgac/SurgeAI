    "yieldOptimization": {
      "enabled": true,
      "supportedProtocols": ["aave", "compound", "uniswap_v3"],
      "rebalanceThreshold": 0.5
    },
    "riskManagement": {
      "enabled": true,
      "stopLoss": 5.0,
      "takeProfit": 10.0,
      "maxPortfolioRisk": 25.0
    }
  },
  "performance": {
    "totalTrades": 0,
    "winRate": 0,
    "totalProfit": 0,
    "sharpeRatio": 0
  }
